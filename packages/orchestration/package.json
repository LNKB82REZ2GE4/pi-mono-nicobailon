{
  "name": "@mariozechner/pi-orchestration",
  "version": "0.0.1",
  "description": "Multi-agent orchestration for pi - chains, parallel agents, and specialist teams",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "agents"
  ],
  "scripts": {
    "build": "tsc",
    "check": "tsc --noEmit"
  },
  "keywords": [
    "pi",
    "agent",
    "orchestration",
    "multi-agent",
    "ai"
  ],
  "author": "Mario Zechner",
  "license": "MIT",
  "dependencies": {
    "@mariozechner/pi-ai": "*",
    "@mariozechner/pi-tui": "*",
    "@mariozechner/pi-coding-agent": "*",
    "@sinclair/typebox": "^0.34.0"
  },
  "devDependencies": {
    "typescript": "^5.8.2"
  },
  "pi": {
    "extensions": ["./dist/index.js"]
  }
}
